# ─────────────────────────────────────────
# SECURITY — never commit secrets or user data
# ─────────────────────────────────────────
.env
.env.*
!**/.env.example          # keep the template in any subdirectory

# SQLite database files (contain real student data)
*.db
*.db-shm
*.db-wal
database/redmushroom.db

# Generated PDF reports (may contain student PII)
*.pdf
backend/public/reports/

# ─────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/
scripts/node_modules/

# ─────────────────────────────────────────
# BUILD OUTPUT
# ─────────────────────────────────────────
dist/
build/
frontend/dist/
backend/dist/

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─────────────────────────────────────────
# TEST ARTEFACTS
# ─────────────────────────────────────────
coverage/
playwright-report/
test-results/
.playwright/

# ─────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─────────────────────────────────────────
# EDITOR / IDE
# ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # keep recommended extensions
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─────────────────────────────────────────
# TEMP / MISC
# ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
