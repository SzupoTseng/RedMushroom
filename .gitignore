# ─────────────────────────────────────────
# SECURITY — never commit secrets or user data
# ─────────────────────────────────────────
.env
.env.*
!**/.env.example          # keep the template in any subdirectory

# SQLite database files (contain real student data)
*.db
*.db-shm
*.db-wal
database/redmushroom.db

# Generated PDF reports (may contain student PII)
*.pdf
backend/public/reports/

# Portable Node 22 downloaded by start.bat / reinstall.bat when the
# system Node is too new for better-sqlite3 prebuilds. ~150 MB extracted.
.tools/

# ─────────────────────────────────────────
# SCRAPE PIPELINE — downloaded third-party content + Python venv
# ─────────────────────────────────────────
# IP 風險：scripts/scrape/data/ 內含從學校官網下載的段考 PDF / 解析後的考題文字 /
# 結構化題目。整批是第三方教材衍生品，不可上 git。需重跑時用 hub.py 系列腳本重產。
scripts/scrape/data/
# Python 虛擬環境（~144 MB，可由 README 指令重建）
scripts/scrape/.venv/
**/.venv/
# Python 編譯快取
__pycache__/
*.pyc
*.pyo

# ─────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/
scripts/node_modules/

# ─────────────────────────────────────────
# BUILD OUTPUT
# ─────────────────────────────────────────
dist/
build/
frontend/dist/
backend/dist/

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─────────────────────────────────────────
# TEST ARTEFACTS
# ─────────────────────────────────────────
coverage/
playwright-report/
test-results/
.playwright/

# ─────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─────────────────────────────────────────
# EDITOR / IDE
# ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # keep recommended extensions
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─────────────────────────────────────────
# TEMP / MISC
# ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
# scripts/package-lock.json is REQUIRED for reproducible CI builds
# (`npm ci` in the Docker entrypoint needs it). Do NOT ignore.
